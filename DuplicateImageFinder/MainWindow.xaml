<ui:FluentWindow x:Class="ImageCollectionTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ImageCollectionTool"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Image Collection Tool" Height="620" Width="500"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="48" />
            <RowDefinition Height="40" />
            <RowDefinition Height="36" />
            <RowDefinition Height="48" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <ui:TitleBar
            Grid.Row="0"
            Title="Image Collection Tool" />

        <!-- Folder selection -->
        <Grid Grid.Row="1" Margin="10 0 10 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Name="folderText"
                Grid.Column="0"
                VerticalAlignment="Center"
                TextTrimming="CharacterEllipsis"
                Text="Current Folder: "/>
            <ui:Button
                Grid.Column="1"
                Icon="{ui:SymbolIcon FolderOpen24}"
                Content="Select Folder"
                VerticalAlignment="Center"
                Click="SelectFolder_Click" />
        </Grid>

        <!-- Output -->
        <TextBox
            Name="mainTextBox"
            Grid.Row="2"
            Margin="10 0 10 0"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Auto"/>

        <!-- Action buttons -->
        <StackPanel
            Orientation="Horizontal"
            Grid.Row="3"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <ui:Button
                Name="DeleteDuplicatesButton"
                Width="160"
                Margin="0 0 10 0"
                IsEnabled="False"
                Appearance="Danger"
                Icon="{ui:SymbolIcon Delete24}"
                Content="Delete Duplicates" Click="DeleteDuplicates_Click" />

            <ui:Button
                Name="FixNumberingButton"
                Width="140"
                IsEnabled="False"
                Icon="{ui:SymbolIcon NumberSymbol24}"
                Content="Fix Numbering" Click="FixNumbering_Click" />

        </StackPanel>

        <!-- Common words -->
        <Grid Grid.Row="4" Margin="10 0 10 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="Common words in file name:"/>
            <TextBox
                Name="commonWordsTextBox"
                Grid.Column="1"
                Margin="10 0 0 0"
                VerticalAlignment="Center"
                KeyDown="commonWordsTextBox_KeyDown"/>
        </Grid>

        <!-- Duplicate check -->
        <StackPanel
            Orientation="Horizontal"
            Grid.Row="5"
            VerticalAlignment="Center"
            Margin="10 0 0 0">
            <CheckBox
                Name="findDuplicatesCheckBox" />
            <TextBlock
                Text="Check for duplicate images?"
                Margin="8 0 0 0"
                VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Run -->
        <ui:Button
            Name="RunButton"
            Grid.Row="6"
            Width="100"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Appearance="Primary"
            Icon="{ui:SymbolIcon Play24}"
            Content="Run" Click="Run_Click" />
    </Grid>
</ui:FluentWindow>
