<ui:FluentWindow x:Class="ImageCollectionTool.Views.ImageComparisonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Compare Images" MinHeight="300" MinWidth="400"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45" />
            <RowDefinition Height="1" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Compare Images" />
        <Rectangle Grid.Row="1" Fill="{DynamicResource ControlStrokeColorDefaultBrush}" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Image 1 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Image Grid.Row="0" x:Name="Image1" Stretch="Uniform" Margin="8" />
                <TextBlock Grid.Row="1" x:Name="FileName1Text"
                           HorizontalAlignment="Center" Margin="8 0 8 8"
                           TextTrimming="CharacterEllipsis" />
            </Grid>

            <Rectangle Grid.Column="1" Fill="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0 8" />

            <!-- Image 2 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Image Grid.Row="0" x:Name="Image2" Stretch="Uniform" Margin="8" />
                <TextBlock Grid.Row="1" x:Name="FileName2Text"
                           HorizontalAlignment="Center" Margin="8 0 8 8"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
